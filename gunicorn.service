[Unit]
Description=gunicorn daemon
Requires=gunicorn.socket
After=network.target

[Service]
User=jenkins
Group=jenkins
WorkingDirectory=/var/lib/jenkins/workspace/django/
ExecStart=/var/lib/jenkins/workspace/django/env/bin/gunicorn \ 
          --access-logfile - \
          --workers 3 \
          --bind unix:/var/lib/jenkins/workspace/django/django_web_app.sock \
          django_web_app.wsgi:application

[Install]
WantedBy=multi-user.target
