[Unit]
Description=gunicorn daemon
Requires=gunicorn.socket
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/var/lib/jenkins/workspace/django/app
ExecStart=/var/lib/jenkins/workspace/django/env/bin/gunicorn 
           --workers 1 
           --log-level debug 
           --error-logfile /var/lib/jenkins/workspace/django/error.log 
           --bind unix:/var/lib/jenkins/workspace/django/run/gunicorn.sock  \ django_web_app.wsgi:application

[Install]
WantedBy=multi-user.target
